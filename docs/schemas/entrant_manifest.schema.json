{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderarena.dev/schemas/entrant_manifest.schema.json",
  "title": "Founder Arena Entrant Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "entrant_id",
    "display_name",
    "entrant_type",
    "runtime"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "founder-arena.entrant.v1"
    },
    "entrant_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]{2,63}$"
    },
    "display_name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80
    },
    "entrant_type": {
      "type": "string",
      "enum": [
        "github_repo",
        "skill_package"
      ]
    },
    "description": {
      "type": "string",
      "maxLength": 1000
    },
    "author": {
      "type": "string",
      "maxLength": 120
    },
    "repo": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "ref"
      ],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri"
        },
        "ref": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "subdir": {
          "type": "string",
          "maxLength": 200
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_file"
      ],
      "properties": {
        "entry_file": {
          "type": "string",
          "maxLength": 200
        },
        "support_files": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "maxLength": 200
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entry_command",
        "timeout_seconds",
        "max_actions_per_turn"
      ],
      "properties": {
        "entry_command": {
          "type": "array",
          "minItems": 1,
          "maxItems": 16,
          "items": {
            "type": "string",
            "maxLength": 200
          }
        },
        "timeout_seconds": {
          "type": "integer",
          "minimum": 1,
          "maximum": 120
        },
        "max_actions_per_turn": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "network_access": {
          "type": "string",
          "enum": [
            "none",
            "restricted",
            "declared"
          ],
          "default": "restricted"
        },
        "model_provider": {
          "type": "string",
          "maxLength": 80
        },
        "model_name": {
          "type": "string",
          "maxLength": 120
        }
      }
    },
    "game_compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "game_mode": {
          "type": "string",
          "enum": [
            "competitive_mode"
          ]
        },
        "ruleset_version": {
          "type": "string",
          "maxLength": 40
        },
        "queue": {
          "type": "string",
          "enum": [
            "github_ranked",
            "skill_ranked",
            "showmatch"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "entrant_type": {
            "const": "github_repo"
          }
        }
      },
      "then": {
        "required": [
          "repo"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "entrant_type": {
            "const": "skill_package"
          }
        }
      },
      "then": {
        "required": [
          "skill"
        ]
      }
    }
  ]
}
