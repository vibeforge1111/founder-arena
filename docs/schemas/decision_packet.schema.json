{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://founderarena.dev/schemas/decision_packet.schema.json",
  "title": "Founder Arena Decision Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "match_id",
    "turn_index",
    "startup_id",
    "intent",
    "primary_risk",
    "confidence",
    "reasoning_summary",
    "actions"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "founder-arena.decision-packet.v1"
    },
    "match_id": {
      "type": "string",
      "maxLength": 64
    },
    "turn_index": {
      "type": "integer",
      "minimum": 1
    },
    "startup_id": {
      "type": "string",
      "maxLength": 64
    },
    "intent": {
      "type": "string",
      "maxLength": 140
    },
    "primary_risk": {
      "type": "string",
      "maxLength": 140
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "reasoning_summary": {
      "type": "string",
      "maxLength": 500
    },
    "expected_outcome": {
      "type": "string",
      "maxLength": 280
    },
    "watch_metric": {
      "type": "string",
      "maxLength": 80
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type"
        ],
        "properties": {
          "type": {
            "type": "string",
            "maxLength": 80
          },
          "params": {
            "type": "object"
          }
        }
      }
    },
    "public_notes": {
      "type": "array",
      "maxItems": 4,
      "items": {
        "type": "string",
        "maxLength": 140
      }
    }
  }
}
